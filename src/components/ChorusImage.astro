---
import { Image } from "astro:assets";
import chorusImage from "../assets/liedertafel-mining.jpeg";

interface Props {
	alt?: string;
	backgroundPosition?: string;
}

const {
	alt = "Die Liedertafel Mining beim gemeinsamen Singen",
	backgroundPosition = "center bottom",
} = Astro.props;
---

<section class="chorus-image" role="img" aria-label={alt}>
	<Image
		src={chorusImage}
		alt=""
		aria-hidden="true"
		loading="lazy"
		class="chorus-image__photo"
		style={`object-position: ${backgroundPosition}`}
	/>
	<div class="chorus-image__overlay" aria-hidden="true"></div>
</section>

<style>
	.chorus-image {
		position: relative;
		min-height: clamp(20rem, 50vh, 30rem);
		width: 100%;
		max-width: 1100px;
		margin: 0 auto;
		overflow: hidden;
	}

	.chorus-image__photo {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.chorus-image__overlay {
		position: absolute;
		inset: 0;
		background: radial-gradient(50% 50% at 50% 50%, rgba(0, 0, 0, 0.12), transparent 60%);
		z-index: 1;
	}
</style>
