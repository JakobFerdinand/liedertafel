---
import HomeNavbar from "../components/HomeNavbar.astro";
---

<!doctype html>
<html lang="de">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content="Liedertafel Mining 1906 - Ein traditionsreicher Männergesangverein in Mining am Inn mit über 100 Jahren Geschichte." />
		<meta name="theme-color" content="#823c41" />
		<meta property="og:title" content="Liedertafel Mining 1906" />
		<meta property="og:description" content="Ein traditionsreicher Männergesangverein in Mining am Inn mit über 100 Jahren Geschichte." />
		<meta property="og:type" content="website" />
		<meta name="twitter:card" content="summary" />
		<title>Liedertafel Mining 1906</title>
		<!-- Google Fonts: Playfair Display for headings, Source Serif 4 for body -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600&family=Source+Serif+4:opsz,wght@8..60,300;600&display=swap" rel="stylesheet" />
	</head>
	<body>
		<HomeNavbar />
		<main>
			<slot />
		</main>
	</body>
</html>

<style is:global>
	*,
	*::before,
	*::after {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		padding: 0;
		width: 100%;
		min-height: 100vh;
		overflow-x: hidden;
	}

	:root {
		--font-heading: 'Playfair Display', Georgia, serif;
		--content-max-width: 800px;
		--color-brand: rgb(130, 60, 65);
	}

	body {
		font-family: 'Source Serif 4', Georgia, 'Times New Roman', serif;
		font-weight: 300;
		background-color: var(--color-brand);
	 color: #ffffff;
	}

	main {
		width: 100%;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 3rem;
		padding: 2rem 0;
	}

	main > * {
		width: 100%;
		max-width: var(--content-max-width);
		padding-left: 2rem;
		padding-right: 2rem;
	}

	main > .chorus-image {
		max-width: none;
		padding-left: 0;
		padding-right: 0;
	}

	/* Global heading styles */
	h1 {
		font-family: var(--font-heading);
		font-size: 2.25rem;
		font-weight: 500;
		margin: 0;
		letter-spacing: 0.02em;
		line-height: 1.2;
	}

	h2 {
		font-family: var(--font-heading);
		font-size: 1.75rem;
		font-weight: 500;
		margin: 0 0 2rem 0;
		letter-spacing: 0.02em;
		line-height: 1.3;
		text-align: center;
	}

	h3 {
		font-family: var(--font-heading);
		font-size: 1.5rem;
		font-weight: 500;
		margin: 0;
		letter-spacing: 0.01em;
		line-height: 1.3;
	}

	/* Shared ghost button / link style */
	.btn-ghost {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.85rem 2.5rem;
		border: 1px solid rgba(255, 255, 255, 0.4);
		background: rgba(255, 255, 255, 0.12);
		color: #ffffff;
		text-decoration: none;
		font-weight: 600;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		transition: background 0.25s ease, border-color 0.25s ease, transform 0.25s ease;
	}

	.btn-ghost:hover {
		background: rgba(255, 255, 255, 0.2);
		border-color: rgba(255, 255, 255, 0.7);
		transform: translateY(-2px);
	}

	/* Shared inline link with underline */
	.link-underline {
		color: rgba(255, 255, 255, 0.92);
		text-decoration: none;
		border-bottom: 1px solid rgba(255, 255, 255, 0.35);
		transition: border-color 0.2s ease, color 0.2s ease;
		font-weight: 600;
		letter-spacing: 0.02em;
	}

	.link-underline:hover {
		color: #ffffff;
		border-bottom-color: rgba(255, 255, 255, 0.85);
	}

	/* Responsive heading adjustments */
	@media (max-width: 600px) {
		h1 {
			font-size: 1.75rem;
		}

		h2 {
			font-size: 1.5rem;
		}

		h3 {
			font-size: 1.25rem;
		}
	}
</style>
