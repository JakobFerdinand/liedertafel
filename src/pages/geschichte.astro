---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import { getCollection, render } from "astro:content";
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";

interface TimelineEntry {
	id: string;
	date: string;
	formattedDate: string;
	title: string;
	subtitle?: string;
	image?: ImageMetadata;
	hasContent: boolean;
	Content: Awaited<ReturnType<typeof render>>["Content"];
}

interface TimelineGroupDefinition {
	title: string;
	from: number;
	message?: string;
}

interface TimelineGroup extends TimelineGroupDefinition {
	to?: number;
	rangeLabel: string;
	entries: TimelineEntry[];
}

const formatHistoryDate = (rawDate: string) => {
	if (/^\d{4}$/.test(rawDate)) {
		return rawDate;
	}

	if (/^\d{4}-\d{2}$/.test(rawDate)) {
		const [year, month] = rawDate.split("-").map(Number);
		const parsedDate = new Date(Date.UTC(year, month - 1, 1));

		return new Intl.DateTimeFormat("de-AT", {
			month: "long",
			year: "numeric",
			timeZone: "UTC",
		}).format(parsedDate);
	}

	if (/^\d{4}-\d{2}-\d{2}$/.test(rawDate)) {
		const [year, month, day] = rawDate.split("-").map(Number);
		const parsedDate = new Date(Date.UTC(year, month - 1, day));

		return new Intl.DateTimeFormat("de-AT", {
			day: "2-digit",
			month: "long",
			year: "numeric",
			timeZone: "UTC",
		}).format(parsedDate);
	}

	return rawDate;
};

const getHistoryYear = (rawDate: string) => Number.parseInt(rawDate.slice(0, 4), 10);

const historyEntries = await getCollection("history");
const historyGroupEntries = await getCollection("historyGroups");

if (historyGroupEntries.length > 1) {
	throw new Error("Expected a single historyGroups entry in src/content/history-groups.");
}

const timelineEntries = await Promise.all(
	historyEntries
		.sort((first: (typeof historyEntries)[number], second: (typeof historyEntries)[number]) => second.data.date.localeCompare(first.data.date))
		.map(async (entry) => {
			const { Content } = await render(entry);

			return {
				id: entry.id,
				date: entry.data.date,
				formattedDate: formatHistoryDate(entry.data.date),
				title: entry.data.title,
				subtitle: entry.data.subtitle,
				image: entry.data.image,
				hasContent: (entry.body?.trim().length ?? 0) > 0,
				Content,
			} satisfies TimelineEntry;
		}),
);

const configuredGroupDefinitions = historyGroupEntries[0]?.data.groups;
const visibleTimelineGroups: TimelineGroup[] = [];

if (timelineEntries.length > 0) {
	const earliestHistoryYear = timelineEntries.reduce(
		(earliestYear, entry) => Math.min(earliestYear, getHistoryYear(entry.date)),
		Number.POSITIVE_INFINITY,
	);

	const groupDefinitions: TimelineGroupDefinition[] = (
		configuredGroupDefinitions?.length ? configuredGroupDefinitions : [{ title: "Geschichte", from: earliestHistoryYear }]
	)
		.slice()
		.sort((first: TimelineGroupDefinition, second: TimelineGroupDefinition) => first.from - second.from);

	const timelineGroups: TimelineGroup[] = groupDefinitions.map((group, index) => {
		const nextGroup = groupDefinitions[index + 1];
		const to = nextGroup ? nextGroup.from - 1 : undefined;
		const rangeStart = index === 0 ? Math.min(group.from, earliestHistoryYear) : group.from;

		return {
			...group,
			to,
			rangeLabel: to ? `${rangeStart}-${to}` : `ab ${rangeStart}`,
			entries: [],
		};
	});

	timelineEntries.forEach((entry) => {
		const entryYear = getHistoryYear(entry.date);
		const groupIndex = groupDefinitions.findLastIndex((group) => entryYear >= group.from);
		const targetGroup = timelineGroups[groupIndex >= 0 ? groupIndex : 0];

		targetGroup?.entries.push(entry);
	});

	visibleTimelineGroups.push(...timelineGroups.filter((group) => group.entries.length > 0).reverse());
}
---

<Layout>
	<section class="history-hero">
		<p class="history-hero__eyebrow">Vereinschronik</p>
		<h1>Geschichte der Liedertafel Mining</h1>
		<p>Stationen unseres Chors - von der Gründung bis heute.</p>
	</section>

	<section class="timeline" aria-labelledby="timeline-heading">
		<h2 class="timeline-heading" id="timeline-heading">Zeitleiste</h2>
		{visibleTimelineGroups.length > 0 ? (
			<ul class="timeline-list timeline-list--grouped">
				{
					visibleTimelineGroups.map((group) => (
						<li class="timeline-group-item" aria-labelledby={`timeline-group-${group.from}`}>
							<details class="timeline-group__details">
								<summary class="timeline-group__header">
									<h3 class="timeline-group__title" id={`timeline-group-${group.from}`}>{group.title}</h3>
									<p class="timeline-group__range">{group.rangeLabel}</p>
									<p class="timeline-group__count">
										{group.entries.length} {group.entries.length === 1 ? "Eintrag" : "Einträge"}
									</p>
								</summary>
								{group.message && (
									<p class="timeline-group__message">{group.message}</p>
								)}
								<ul class="timeline-list timeline-group__entries">
									{group.entries.map((entry) => (
										<li class="timeline-item" id={entry.id}>
											<details class="timeline-details" data-history-entry={entry.id} open={false}>
												<summary>
													<span class="timeline-date">{entry.formattedDate}</span>
													<div class="timeline-header">
														<h4>{entry.title}</h4>
														{entry.subtitle && <p>{entry.subtitle}</p>}
													</div>
												</summary>
												{(entry.image || entry.hasContent) && (
													<div class="timeline-content">
														{entry.image && (
															<button
																type="button"
																class="timeline-image-trigger"
																data-image-src={entry.image.src}
																data-image-alt={`Bild zu ${entry.title}`}
																aria-label={`Bild zu ${entry.title} vergrößern`}
															>
																<Image src={entry.image} alt={`Bild zu ${entry.title}`} loading="lazy" />
															</button>
														)}
														{entry.hasContent && <entry.Content />}
													</div>
												)}
											</details>
										</li>
									))}
								</ul>
							</details>
						</li>
					))
				}
			</ul>
		) : (
			<p class="timeline-empty">Noch keine Chronik-Einträge vorhanden.</p>
		)}
	</section>

	<dialog class="image-lightbox" aria-label="Bild vergrößert anzeigen">
		<button type="button" class="lightbox-close" aria-label="Vollbildansicht schließen">x</button>
		<button type="button" class="lightbox-nav lightbox-nav--prev" aria-label="Vorheriges Bild anzeigen">
			&lt;
		</button>
		<button type="button" class="lightbox-nav lightbox-nav--next" aria-label="Nächstes Bild anzeigen">
			&gt;
		</button>
		<figure class="lightbox-figure">
			<img class="lightbox-image" src="" alt="" />
			<figcaption class="lightbox-caption"></figcaption>
		</figure>
	</dialog>

	<Footer />
</Layout>

<script>
	const lightbox = document.querySelector<HTMLDialogElement>(".image-lightbox");
	const lightboxImage = lightbox?.querySelector<HTMLImageElement>(".lightbox-image");
	const lightboxCaption = lightbox?.querySelector<HTMLElement>(".lightbox-caption");
	const closeButton = lightbox?.querySelector<HTMLButtonElement>(".lightbox-close");
	const previousButton = lightbox?.querySelector<HTMLButtonElement>(".lightbox-nav--prev");
	const nextButton = lightbox?.querySelector<HTMLButtonElement>(".lightbox-nav--next");
	const triggers = document.querySelectorAll<HTMLButtonElement>(".timeline-image-trigger");
	const markdownImages = document.querySelectorAll<HTMLImageElement>(".timeline-content img");
	const timelineContents = document.querySelectorAll<HTMLElement>(".timeline-content");
	const historyDetails = document.querySelectorAll<HTMLDetailsElement>(".timeline-details[data-history-entry]");

	const updateHistoryHash = (entryId?: string) => {
		const url = new URL(window.location.href);

		if (entryId) {
			url.hash = entryId;
			history.pushState(null, "", url);
			return;
		}

		if (!url.hash) {
			return;
		}

		url.hash = "";
		history.pushState(null, "", url);
	};

	const openHistoryEntry = (entryId: string, shouldScroll = true) => {
		const entry = document.getElementById(entryId);
		const details = document.querySelector<HTMLDetailsElement>(`[data-history-entry="${CSS.escape(entryId)}"]`);

		if (!entry || !details) {
			return;
		}

		// Also open the parent group if it is collapsed
		const groupDetails = details.closest<HTMLDetailsElement>(".timeline-group__details");
		if (groupDetails && !groupDetails.open) {
			groupDetails.open = true;
		}

		if (!details.open) {
			details.open = true;
		}

		if (shouldScroll) {
			requestAnimationFrame(() => {
				entry.scrollIntoView({
					behavior: "smooth",
					block: "start",
				});
			});
		}
	};

	const syncHistoryEntryFromHash = () => {
		const entryId = decodeURIComponent(window.location.hash.slice(1));

		if (!entryId) {
			return;
		}

		openHistoryEntry(entryId);
	};

	type LightboxItem = {
		trigger: HTMLElement;
		getSource: () => string;
		getAlt: () => string;
	};

	let triggerElement: HTMLElement | null = null;
	let currentGroup: LightboxItem[] = [];
	let currentIndex = -1;

	const groupLookup = new Map<HTMLElement, LightboxItem[]>();
	const indexLookup = new Map<HTMLElement, number>();

	const setNavigationState = () => {
		const hasMultipleImages = currentGroup.length > 1;

		previousButton?.toggleAttribute("hidden", !hasMultipleImages);
		nextButton?.toggleAttribute("hidden", !hasMultipleImages);

		if (!hasMultipleImages) {
			if (previousButton) {
				previousButton.disabled = true;
			}

			if (nextButton) {
				nextButton.disabled = true;
			}

			return;
		}

		if (previousButton) {
			previousButton.disabled = currentIndex <= 0;
		}

		if (nextButton) {
			nextButton.disabled = currentIndex >= currentGroup.length - 1;
		}
	};

	const showImageAtIndex = (index: number) => {
		if (!lightboxImage || index < 0 || index >= currentGroup.length) {
			return;
		}

		currentIndex = index;
		const item = currentGroup[currentIndex];
		const alt = item.getAlt();

		lightboxImage.src = item.getSource();
		lightboxImage.alt = alt;
		if (lightboxCaption) {
			lightboxCaption.textContent = alt;
		}

		setNavigationState();
	};

	const openLightbox = (trigger: HTMLElement) => {
		if (!lightbox || !lightboxImage) {
			return;
		}

		triggerElement = trigger;
		currentGroup = groupLookup.get(trigger) ?? [];
		currentIndex = indexLookup.get(trigger) ?? 0;
		showImageAtIndex(currentIndex);
		lightbox.showModal();
	};

	const showPreviousImage = () => {
		showImageAtIndex(currentIndex - 1);
	};

	const showNextImage = () => {
		showImageAtIndex(currentIndex + 1);
	};

	const closeLightbox = () => {
		if (lightbox?.open) {
			lightbox.close();
			currentGroup = [];
			currentIndex = -1;
			triggerElement?.focus();
		}
	};

	timelineContents.forEach((content) => {
		const items: LightboxItem[] = [];

		const trigger = content.querySelector<HTMLButtonElement>(".timeline-image-trigger");
		if (trigger) {
			items.push({
				trigger,
				getSource: () => trigger.dataset.imageSrc ?? "",
				getAlt: () => trigger.dataset.imageAlt ?? "",
			});
		}

		content.querySelectorAll<HTMLImageElement>("img").forEach((image) => {
			if (image.closest(".timeline-image-trigger")) {
				return;
			}

			items.push({
				trigger: image,
				getSource: () => image.currentSrc || image.src,
				getAlt: () => image.alt,
			});
		});

		items.forEach((item, index) => {
			groupLookup.set(item.trigger, items);
			indexLookup.set(item.trigger, index);
		});
	});

	historyDetails.forEach((details) => {
		const entryId = details.dataset.historyEntry;

		if (!entryId) {
			return;
		}

		details.addEventListener("toggle", () => {
			if (details.open) {
				updateHistoryHash(entryId);
				return;
			}

			if (decodeURIComponent(window.location.hash.slice(1)) === entryId) {
				updateHistoryHash();
			}
		});
	});

	triggers.forEach((trigger) => {
		trigger.addEventListener("click", () => {
			openLightbox(trigger);
		});
	});

	markdownImages.forEach((image) => {
		if (image.closest(".timeline-image-trigger")) {
			return;
		}

		image.classList.add("timeline-markdown-image");
		image.setAttribute("role", "button");
		image.setAttribute("tabindex", "0");
		image.setAttribute("aria-label", `${image.alt || "Bild"} vergrößern`);

		image.addEventListener("click", () => {
			openLightbox(image);
		});

		image.addEventListener("keydown", (event) => {
			if (event.key !== "Enter" && event.key !== " ") {
				return;
			}

			event.preventDefault();
			openLightbox(image);
		});
	});

	closeButton?.addEventListener("click", closeLightbox);
	previousButton?.addEventListener("click", showPreviousImage);
	nextButton?.addEventListener("click", showNextImage);

	lightbox?.addEventListener("click", (event) => {
		const target = event.target;
		if (target instanceof HTMLDialogElement) {
			closeLightbox();
		}
	});

	document.addEventListener("keydown", (event) => {
		if (!lightbox?.open) {
			return;
		}

		if (event.key === "ArrowLeft") {
			event.preventDefault();
			showPreviousImage();
		}

		if (event.key === "ArrowRight") {
			event.preventDefault();
			showNextImage();
		}
	});

	window.addEventListener("hashchange", syncHistoryEntryFromHash);
	syncHistoryEntryFromHash();
</script>

<style>
	.history-hero {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		text-align: center;
	}

	.history-hero__eyebrow {
		text-transform: uppercase;
		letter-spacing: 0.2em;
		font-size: 0.85rem;
		font-weight: 600;
		margin: 0;
		opacity: 0.8;
	}

	.history-hero p {
		margin: 0;
		line-height: 1.6;
		opacity: 0.9;
	}

	.timeline {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.timeline-list {
		--timeline-gap: 1rem;
		--timeline-dot-top: 1.575rem;
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: var(--timeline-gap);
	}

	.timeline-list > li {
		position: relative;
		--timeline-item-padding-left: 2rem;
		--timeline-marker-x: 0.5rem;
		padding-left: var(--timeline-item-padding-left);
	}

	.timeline-list > li::before {
		content: "";
		position: absolute;
		left: var(--timeline-marker-x);
		top: 0;
		bottom: calc(-1 * var(--timeline-gap));
		width: 2px;
		background: rgba(255, 255, 255, 0.3);
		transform: translateX(-50%);
	}

	.timeline-list > li:last-child::before {
		bottom: calc(100% - var(--timeline-dot-top));
	}

	.timeline-group__details {
		width: 100%;
	}

	.timeline-group__details > summary {
		list-style: none;
		cursor: pointer;
	}

	.timeline-group__details > summary::-webkit-details-marker {
		display: none;
	}

	.timeline-group__entries {
		--timeline-gap: 1rem;
		--timeline-dot-top: 1.575rem;
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: var(--timeline-gap);
		margin-top: var(--timeline-gap);
	}

	.timeline-group__entries > li {
		position: relative;
		--timeline-item-padding-left: 2rem;
		--timeline-marker-x: 0.5rem;
		padding-left: var(--timeline-item-padding-left);
	}

	.timeline-group__entries > li::before {
		content: "";
		position: absolute;
		left: var(--timeline-marker-x);
		top: 0;
		bottom: calc(-1 * var(--timeline-gap));
		width: 2px;
		background: rgba(255, 255, 255, 0.3);
		transform: translateX(-50%);
	}

	.timeline-group__entries > li:last-child::before {
		bottom: calc(100% - var(--timeline-dot-top));
	}

	.timeline-heading {
		margin: 0;
		font-size: 1.6rem;
		text-align: left;
	}

	.timeline-empty {
		margin: 0;
		line-height: 1.6;
		opacity: 0.9;
	}

	.timeline-group-item {
		position: relative;
		--timeline-dot-top: 1.7rem;
	}

	.timeline-group-item::after {
		content: "";
		position: absolute;
		left: var(--timeline-marker-x);
		top: var(--timeline-dot-top);
		width: 0.95rem;
		height: 0.95rem;
		border-radius: 999px;
		border: 2px solid rgba(255, 255, 255, 0.78);
		background: rgba(255, 255, 255, 0.12);
		box-shadow: 0 0 0 0.35rem rgba(255, 255, 255, 0.06);
		transform: translate(-50%, -50%);
	}

	.timeline-group__header {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 0.9rem;
		align-items: start;
		padding: 0.8rem 0 0.35rem 1.35rem;
	}

	.timeline-group__title {
		display: flex;
		align-items: center;
		padding: 0.35rem 0.8rem;
		border: 1px solid rgba(255, 255, 255, 0.28);
		background: rgba(255, 255, 255, 0.08);
		grid-column: 1 / -1;
		grid-row: 1;
		width: 100%;
	}

	.timeline-group__header h3 {
		margin: 0;
		text-align: left;
		font-size: 1.55rem;
	}

	.timeline-group__range,
	.timeline-group__count {
		margin: 0;
	}

	.timeline-group__message {
		margin: 0 0 1rem calc(-1 * var(--timeline-item-padding-left) + var(--timeline-marker-x) - 1px);
		padding: 0.9rem 1.35rem 0.9rem calc(var(--timeline-item-padding-left) - var(--timeline-marker-x) + 1px);
		line-height: 1.65;
		opacity: 0.9;
		border-left: 2px solid rgba(255, 255, 255, 0.3);
		white-space: pre-line;
	}

	.timeline-group__range {
		grid-column: 1;
		grid-row: 2;
		font-size: 0.8rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		white-space: nowrap;
	}

	.timeline-group__count {
		grid-column: 2;
		grid-row: 2;
		align-self: start;
		font-size: 0.95rem;
		opacity: 0.75;
		text-align: right;
		white-space: nowrap;
	}

	.timeline-item {
		--timeline-dot-top: 1.575rem;
	}

	.timeline-details {
		background: linear-gradient(135deg, rgba(255, 255, 255, 0.1) 0%, rgba(255, 255, 255, 0.04) 100%);
		border: 1px solid rgba(255, 255, 255, 0.2);
		box-shadow: 0 8px 24px rgba(0, 0, 0, 0.16);
	}

	.timeline-details summary {
		list-style: none;
		cursor: pointer;
		padding: 1.2rem 1.2rem 1.2rem 1.35rem;
		display: grid;
		grid-template-columns: auto minmax(0, 1fr);
		gap: 0.9rem;
		align-items: start;
		position: relative;
	}

	.timeline-details summary::-webkit-details-marker {
		display: none;
	}

	.timeline-details summary::before {
		content: "";
		position: absolute;
		left: calc(var(--timeline-marker-x) - var(--timeline-item-padding-left));
		top: var(--timeline-dot-top);
		width: 0.75rem;
		height: 0.75rem;
		border-radius: 999px;
		border: 2px solid rgba(255, 255, 255, 0.78);
		background: var(--color-brand);
		transform: translate(-50%, -50%);
	}

	.timeline-date {
		font-size: 0.85rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		opacity: 0.85;
		white-space: nowrap;
		width: 10rem;
		flex-shrink: 0;
	}

	.timeline-header h4 {
		font-family: var(--font-heading);
		font-size: 1.3rem;
		font-weight: 500;
		margin: 0;
		letter-spacing: 0.01em;
		line-height: 1.3;
	}

	.timeline-header p {
		margin: 0.45rem 0 0;
		opacity: 0.9;
		line-height: 1.5;
	}

	.timeline-content {
		padding: 0 1.2rem 1.2rem 1.35rem;
		border-top: 1px solid rgba(255, 255, 255, 0.12);
	}

	.timeline-content :global(p) {
		margin: 1rem 0 0;
		line-height: 1.65;
		opacity: 0.95;
	}

	.timeline-image-trigger img {
		display: block;
		width: 100%;
		max-height: 280px;
		object-fit: contain;
		margin-top: 0;
	}

	.timeline-content :global(img.timeline-markdown-image) {
		display: block;
		width: auto;
		max-width: 100%;
		height: auto;
		margin-top: 1rem;
		cursor: zoom-in;
	}

	.timeline-image-trigger {
		display: block;
		width: 100%;
		margin: 1rem 0 0;
		padding: 0;
		border: 0;
		background: transparent;
		cursor: zoom-in;
	}

	.image-lightbox {
		padding: 0;
		border: 0;
		background: transparent;
		max-width: min(94vw, 1200px);
		max-height: 94vh;
		color-scheme: normal;
	}

	.image-lightbox::backdrop {
		background: rgba(0, 0, 0, 0.68);
	}

	.lightbox-figure {
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		background: transparent;
	}

	.lightbox-image {
		display: block;
		max-width: 100%;
		max-height: 88vh;
		width: auto;
		height: auto;
		object-fit: contain;
		box-shadow: 0 16px 36px rgba(0, 0, 0, 0.5);
	}

	.lightbox-caption {
		padding: 0.5rem 0 0;
		font-size: 0.85rem;
		color: rgba(255, 255, 255, 0.8);
		text-align: left;
	}

	.lightbox-caption:empty {
		display: none;
	}

	.lightbox-close {
		position: fixed;
		top: 1rem;
		right: 1rem;
		width: 2.25rem;
